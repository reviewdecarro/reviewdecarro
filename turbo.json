{
	"$schema": "https://turborepo.dev/schema.json",
	"globalDependencies": ["**/.env.*local"],
	"globalEnv": ["RESEND_API_KEY", "RESEND_FROM_EMAIL"],
	"tasks": {
		"dev": {
			"cache": false,
			"persistent": true
		},
		"build": {
			"dependsOn": ["^build"],
			"outputs": [".next/**", "!.next/cache/**", "dist/**"]
		},
		"lint": {},
		"test": {},
		"test:e2e": {}
	}
}
