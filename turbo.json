{
	"$schema": "https://turborepo.dev/schema.json",
	"globalDependencies": ["**/.env.*local"],
	"globalEnv": [
		"RESEND_API_KEY",
		"RESEND_FROM_EMAIL",
		"PASSWORD_RESET_BASE_URL",
		"EMAIL_CONFIRMATION_BASE_URL",
		"JWT_SECRET",
		"NODE_ENV",
		"DATABASE_URL",
		"WEB_APP_URL"
	],
	"tasks": {
		"dev": {
			"cache": false,
			"persistent": true
		},
		"build": {
			"dependsOn": ["^build"],
			"outputs": [".next/**", "!.next/cache/**", "dist/**"]
		},
		"lint": {},
		"test": {},
		"test:e2e": {}
	}
}
